---
layout: compress
permalink: /feed.xml
# Atom Feed, reference: https://validator.w3.org/feed/docs/atom.html
---

{% capture source %}
<feed xmlns="http://www.w3.org/2005/Atom">
  <id>{{ "/" | absolute_url }}</id>
  <title>{{ site.title | xml_escape }}</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <author>
    <name>{{ site.social.name | xml_escape }}</name>
    <uri>{{ "/" | absolute_url }}</uri>
  </author>
  <link rel="self" type="application/atom+xml" href="{{ page.url | absolute_url }}"/>
  <link rel="alternate" type="text/html" hreflang="{{ site.alt_lang | default: site.lang }}"
    href="{{ '/' | absolute_url }}"/>
  <generator uri="https://jekyllrb.com/" version="{{ jekyll.version }}">Jekyll</generator>
  <rights>© {{ 'now' | date: '%Y' }} {{ site.social.name | xml_escape }}</rights>
  <icon>{{ site.baseurl }}/assets/img/favicons/favicon.ico</icon>
  <logo>{{ site.baseurl }}/assets/img/favicons/favicon-96x96.png</logo>

{% for post in site.posts limit: 5 %}
  {% assign post_absolute_url = post.url | absolute_url %}
  {% assign author_id = post.author | default: site.social.name %}
  {% assign post_author = site.data.authors[author_id] %}
  <entry>
    <title>{{ post.title | xml_escape }}</title>
    <link href="{{ post_absolute_url }}" rel="alternate" type="text/html" title="{{ post.title | xml_escape }}" />
    <published>{{ post.date | date_to_xmlschema }}</published>
  {% if post.last_modified_at %}
    <updated>{{ post.last_modified_at | date_to_xmlschema }}</updated>
  {% else %}
    <updated>{{ post.date | date_to_xmlschema }}</updated>
  {% endif %}
    <id>{{ post_absolute_url }}</id>
    <content type="text/html" src="{{ post_absolute_url }}" />
    <author>
      <name>{{ post_author.name | default: author_id | xml_escape }}</name>
    </author>

  {% if post.categories %}
    {% for category in post.categories %}
    <category term="{{ category | xml_escape }}" />
    {% endfor %}
  {% endif %}

  {% capture summary %}{% include post-summary.html max_length=400 %}{% endcapture %}
  <summary>{{ summary | strip | xml_escape }}</summary>

  </entry>
{% endfor %}
</feed>
{% endcapture %}
{{ source }}
